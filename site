<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>די לאלימות</title>
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;700;900&family=Rubik:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --crimson: #C0392B;
    --deep-red: #96281B;
    --blush: #F8D7DA;
    --cream: #FFF8F5;
    --warm-white: #FFFCFA;
    --charcoal: #2C2C2C;
    --soft-gray: #888;
    --light-gray: #F2EDE9;
    --accent-gold: #D4A853;
    --text-dark: #1A1A1A;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Heebo', sans-serif;
    background: var(--warm-white);
    color: var(--text-dark);
    overflow-x: hidden;
  }

  /* ─── NAVBAR ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    background: rgba(255,252,250,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(192,57,43,0.12);
    padding: 0 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: box-shadow 0.3s;
  }

  nav.scrolled { box-shadow: 0 2px 24px rgba(192,57,43,0.10); }

  .nav-logo {
    font-family: 'Rubik', sans-serif;
    font-weight: 900;
    font-size: 1.4rem;
    color: var(--crimson);
    letter-spacing: -0.5px;
    text-decoration: none;
    cursor: pointer;
  }

  .nav-links {
    display: flex;
    gap: 0.3rem;
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    font-family: 'Heebo', sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--charcoal);
    text-decoration: none;
    padding: 0.45rem 0.9rem;
    border-radius: 50px;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .nav-links a:hover {
    background: var(--blush);
    color: var(--crimson);
  }

  .nav-links a.active {
    background: var(--crimson);
    color: white;
  }

  /* ─── HERO ─── */
  #hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: var(--warm-white);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-bg::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(192,57,43,0.07) 0%, transparent 70%);
    border-radius: 50%;
    animation: pulse-bg 8s ease-in-out infinite;
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    bottom: -15%;
    left: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(212,168,83,0.07) 0%, transparent 70%);
    border-radius: 50%;
    animation: pulse-bg 10s ease-in-out infinite reverse;
  }

  @keyframes pulse-bg {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.1); opacity: 0.7; }
  }

  .hero-content {
    text-align: center;
    z-index: 2;
    padding: 2rem;
    animation: fadeUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow {
    font-size: 0.85rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--soft-gray);
    margin-bottom: 1.5rem;
    animation: fadeUp 1.2s 0.2s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-title {
    font-family: 'Rubik', sans-serif;
    font-weight: 900;
    font-size: clamp(5rem, 14vw, 11rem);
    line-height: 0.9;
    color: var(--crimson);
    letter-spacing: -3px;
    position: relative;
    animation: fadeUp 1.2s 0.1s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-title span {
    display: block;
  }

  .hero-title .word-di {
    color: var(--text-dark);
    font-size: clamp(3rem, 8vw, 7rem);
    letter-spacing: -1px;
  }

  .hero-title .word-la {
    color: var(--accent-gold);
    font-size: clamp(2rem, 5vw, 4rem);
  }

  .hero-title .word-main {
    background: linear-gradient(135deg, var(--crimson) 0%, var(--deep-red) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    margin-top: 2rem;
    font-size: 1.15rem;
    color: var(--soft-gray);
    font-weight: 300;
    line-height: 1.7;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
    animation: fadeUp 1.2s 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-cta {
    margin-top: 2.5rem;
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    animation: fadeUp 1.2s 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .btn-primary {
    background: var(--crimson);
    color: white;
    border: none;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    font-family: 'Heebo', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(192,57,43,0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(192,57,43,0.4);
  }

  .btn-outline {
    background: transparent;
    color: var(--crimson);
    border: 2px solid var(--crimson);
    padding: 0.8rem 2rem;
    border-radius: 50px;
    font-family: 'Heebo', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-outline:hover {
    background: var(--blush);
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--soft-gray);
    font-size: 0.75rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    animation: bounce 2s ease-in-out infinite;
  }

  .scroll-indicator::after {
    content: '↓';
    font-size: 1.2rem;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ─── SECTIONS SHARED ─── */
  section {
    padding: 5rem 2rem;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-tag {
    font-size: 0.78rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--crimson);
    font-weight: 600;
    margin-bottom: 0.8rem;
  }

  .section-title {
    font-family: 'Rubik', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.1;
    color: var(--text-dark);
    margin-bottom: 2.5rem;
  }

  /* ─── ABOUT ─── */
  #about {
    background: var(--light-gray);
  }

  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .about-card {
    background: white;
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 2px 20px rgba(0,0,0,0.05);
    transition: transform 0.3s, box-shadow 0.3s;
    position: relative;
    overflow: hidden;
  }

  .about-card::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 4px;
    height: 100%;
    background: var(--crimson);
    border-radius: 0 20px 20px 0;
  }

  .about-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 40px rgba(192,57,43,0.12);
  }

  .about-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--blush), var(--crimson));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    margin-bottom: 1rem;
  }

  .about-name {
    font-family: 'Rubik', sans-serif;
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--text-dark);
    margin-bottom: 0.3rem;
  }

  .about-role {
    font-size: 0.85rem;
    color: var(--crimson);
    font-weight: 500;
    margin-bottom: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .about-desc {
    font-size: 0.9rem;
    color: var(--soft-gray);
    line-height: 1.6;
  }

  .about-placeholder {
    font-size: 0.85rem;
    color: #bbb;
    font-style: italic;
  }

  /* ─── BOT ─── */
  #bot {
    background: var(--warm-white);
    text-align: center;
  }

  .bot-card {
    background: linear-gradient(135deg, var(--crimson) 0%, var(--deep-red) 100%);
    border-radius: 28px;
    padding: 3.5rem 2.5rem;
    color: white;
    position: relative;
    overflow: hidden;
    max-width: 600px;
    margin: 0 auto;
  }

  .bot-card::before {
    content: '🤝';
    position: absolute;
    font-size: 12rem;
    opacity: 0.07;
    bottom: -2rem;
    left: -2rem;
    line-height: 1;
  }

  .bot-card h2 {
    font-family: 'Rubik', sans-serif;
    font-weight: 800;
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .bot-card p {
    font-size: 1rem;
    opacity: 0.85;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .btn-white {
    background: white;
    color: var(--crimson);
    border: none;
    padding: 0.9rem 2.2rem;
    border-radius: 50px;
    font-family: 'Heebo', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
  }

  .btn-white:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.2);
  }

  /* ─── SHARED BOARD ─── */
  #shared {
    background: var(--light-gray);
  }

  .board-intro {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .board-intro-text { flex: 1; min-width: 250px; }

  .anon-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--blush);
    color: var(--crimson);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.35rem 0.9rem;
    border-radius: 50px;
    margin-bottom: 1rem;
  }

  .story-form {
    background: white;
    border-radius: 20px;
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: 0 2px 16px rgba(0,0,0,0.05);
  }

  .story-form h3 {
    font-family: 'Rubik', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    margin-bottom: 1.2rem;
    color: var(--text-dark);
  }

  .story-form textarea {
    width: 100%;
    min-height: 120px;
    border: 2px solid var(--light-gray);
    border-radius: 12px;
    padding: 1rem;
    font-family: 'Heebo', sans-serif;
    font-size: 0.95rem;
    resize: vertical;
    transition: border-color 0.2s;
    direction: rtl;
    outline: none;
  }

  .story-form textarea:focus { border-color: var(--crimson); }

  .form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1rem;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .anon-note {
    font-size: 0.82rem;
    color: var(--soft-gray);
  }

  .stories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.2rem;
  }

  .story-card {
    background: white;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 2px 14px rgba(0,0,0,0.05);
    transition: transform 0.2s;
    position: relative;
  }

  .story-card:hover { transform: translateY(-3px); }

  .story-card .quote-mark {
    font-family: 'Rubik', sans-serif;
    font-size: 4rem;
    color: var(--blush);
    line-height: 0.7;
    margin-bottom: 0.5rem;
    display: block;
  }

  .story-card .story-text {
    font-size: 0.92rem;
    color: var(--charcoal);
    line-height: 1.65;
  }

  .story-card .story-meta {
    margin-top: 1rem;
    font-size: 0.78rem;
    color: #bbb;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .story-card .like-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.78rem;
    color: #bbb;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    transition: color 0.2s;
  }

  .story-card .like-btn:hover, .story-card .like-btn.liked { color: var(--crimson); }

  .empty-board {
    text-align: center;
    padding: 3rem;
    color: #ccc;
    font-size: 0.95rem;
  }

  /* ─── PUBLISHED STORIES ─── */
  #stories {
    background: var(--warm-white);
  }

  .published-grid {
    display: grid;
    gap: 2rem;
  }

  .pub-story {
    background: white;
    border-radius: 20px;
    padding: 2.5rem;
    box-shadow: 0 2px 20px rgba(0,0,0,0.05);
    border-right: 5px solid var(--crimson);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .pub-story:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 40px rgba(192,57,43,0.10);
  }

  .pub-story-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.2rem;
    flex-wrap: wrap;
  }

  .pub-label {
    background: var(--blush);
    color: var(--crimson);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
  }

  .pub-story-title {
    font-family: 'Rubik', sans-serif;
    font-weight: 700;
    font-size: 1.3rem;
    color: var(--text-dark);
    flex: 1;
  }

  .pub-story-body {
    font-size: 0.95rem;
    color: var(--soft-gray);
    line-height: 1.75;
  }

  /* ─── ADMIN ─── */
  #admin-panel {
    display: none;
    background: #FFF8F5;
    border: 2px dashed var(--crimson);
    border-radius: 20px;
    padding: 2rem;
    margin-top: 2rem;
  }

  #admin-panel h3 {
    font-family: 'Rubik', sans-serif;
    font-weight: 700;
    color: var(--crimson);
    margin-bottom: 1.2rem;
  }

  .admin-form input, .admin-form textarea {
    width: 100%;
    border: 1.5px solid #ddd;
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-family: 'Heebo', sans-serif;
    font-size: 0.9rem;
    direction: rtl;
    margin-bottom: 0.8rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .admin-form input:focus, .admin-form textarea:focus { border-color: var(--crimson); }
  .admin-form textarea { min-height: 100px; resize: vertical; }

  #login-modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }

  #login-modal.active { display: flex; }

  .modal-box {
    background: white;
    border-radius: 20px;
    padding: 2.5rem;
    width: min(400px, 90vw);
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    text-align: center;
  }

  .modal-box h2 {
    font-family: 'Rubik', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    color: var(--text-dark);
  }

  .modal-box input {
    width: 100%;
    border: 2px solid #eee;
    border-radius: 12px;
    padding: 0.85rem 1rem;
    font-family: 'Heebo', sans-serif;
    font-size: 0.95rem;
    direction: rtl;
    outline: none;
    margin-bottom: 0.8rem;
    transition: border-color 0.2s;
  }

  .modal-box input:focus { border-color: var(--crimson); }

  .modal-close {
    position: absolute;
    top: 1rem; left: 1rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--soft-gray);
  }

  /* ─── FOOTER ─── */
  footer {
    background: var(--charcoal);
    color: #aaa;
    text-align: center;
    padding: 2.5rem 2rem;
    font-size: 0.85rem;
    line-height: 1.8;
  }

  footer strong { color: white; }

  /* ─── TABS ─── */
  .page { display: none; }
  .page.active { display: block; }

  /* ─── TOAST ─── */
  #toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: var(--charcoal);
    color: white;
    padding: 0.8rem 1.8rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 500;
    z-index: 9998;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  #toast.show { transform: translateX(-50%) translateY(0); }

  /* ─── CHAT ─── */
  .msg { display: flex; flex-direction: column; max-width: 80%; }
  .msg.user-msg { align-self: flex-start; align-items: flex-start; }
  .msg.bot-msg  { align-self: flex-end;   align-items: flex-end; }

  .user-bubble {
    background: var(--crimson);
    color: white;
    padding: 0.75rem 1.1rem;
    border-radius: 18px 18px 4px 18px;
    font-size: 0.93rem;
    line-height: 1.6;
    max-width: 100%;
    word-break: break-word;
  }

  .bot-bubble {
    background: var(--light-gray);
    color: var(--text-dark);
    padding: 0.75rem 1.1rem;
    border-radius: 18px 18px 18px 4px;
    font-size: 0.93rem;
    line-height: 1.7;
    max-width: 100%;
    word-break: break-word;
    white-space: pre-wrap;
  }

  .msg-time {
    font-size: 0.7rem;
    color: #ccc;
    margin-top: 0.25rem;
    padding: 0 0.3rem;
  }

  /* Typing dots */
  .dot {
    width: 7px; height: 7px;
    background: var(--soft-gray);
    border-radius: 50%;
    animation: blink 1.2s infinite;
  }
  .dot:nth-child(2) { animation-delay: 0.2s; }
  .dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes blink {
    0%, 80%, 100% { opacity: 0.2; transform: scale(1); }
    40% { opacity: 1; transform: scale(1.2); }
  }

  /* Quick chips */
  .chip {
    background: white;
    border: 1.5px solid rgba(192,57,43,0.2);
    color: var(--crimson);
    padding: 0.4rem 0.9rem;
    border-radius: 50px;
    font-family: 'Heebo', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .chip:hover { background: var(--blush); border-color: var(--crimson); }

  #chat-input:focus { border-color: var(--crimson) !important; }
  #dilemma-situation:focus { border-color: var(--crimson) !important; }
  #dilemma-harms:focus { border-color: #e74c3c !important; }
  #dilemma-benefits:focus { border-color: #27ae60 !important; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 600px) {
    .nav-links a { font-size: 0.8rem; padding: 0.4rem 0.6rem; }
    .hero-title { letter-spacing: -1px; }
    nav { padding: 0 1rem; }
    #chat-window { height: 500px; }
    .msg { max-width: 92%; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav id="navbar">
  <span class="nav-logo" onclick="showPage('home')">די לאלימות</span>
  <ul class="nav-links">
    <li><a href="#" onclick="showPage('home')" id="nav-home" class="active">דף הבית</a></li>
    <li><a href="#" onclick="scrollToAbout()" id="nav-about">קצת עלינו</a></li>
    <li><a href="#" onclick="showPage('bot')" id="nav-bot">בוט עזרה</a></li>
    <li><a href="#" onclick="showPage('shared')" id="nav-shared">לוח שיתופי</a></li>
    <li><a href="#" onclick="showPage('stories')" id="nav-stories">סיפורים מפורסמים</a></li>
  </ul>
</nav>

<!-- HOME PAGE -->
