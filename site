  <span style="font-size:0.8rem; opacity:0.6;">כל הסיפורים המשותפים נשמרים באנונימיות מלאה</span>
</footer>

<script>
  // ─── STATE ───
  const ADMIN_PASS = "sh_or_ef2026"; // שנו את הסיסמה!
  let isAdmin = false;
  let stories = JSON.parse(localStorage.getItem('shared_stories') || '[]');
  let likes = JSON.parse(localStorage.getItem('story_likes') || '{}');
  let publishedStories = JSON.parse(localStorage.getItem('published_stories') || '[]');

  // ─── NAV ───
  function showPage(name) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.getElementById('page-' + name).classList.add('active');
    document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
    const map = { home: 'nav-home', bot: 'nav-bot', shared: 'nav-shared', stories: 'nav-stories' };
    if (map[name]) document.getElementById(map[name]).classList.add('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
    if (name === 'shared') renderSharedStories();
    if (name === 'stories') renderPublishedStories();
    return false;
  }

  function scrollToAbout() {
    showPage('home');
    setTimeout(() => {
      document.getElementById('about').scrollIntoView({ behavior: 'smooth' });
    }, 100);
    return false;
  }

  // ─── NAVBAR SCROLL ───
  window.addEventListener('scroll', () => {
    document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 20);
  });

  // ─── TOAST ───
  function toast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2800);
  }

  // ─── SHARED STORIES ───
  function postStory() {
    const text = document.getElementById('story-input').value.trim();
    if (!text) return toast('אנא כתבי משהו לפני פרסום 💜');
    stories.unshift({ text, time: Date.now(), likes: 0 });
    localStorage.setItem('shared_stories', JSON.stringify(stories));
    document.getElementById('story-input').value = '';
    renderSharedStories();
    toast('הסיפור שלך פורסם באנונימיות 💜');
  }

  function renderSharedStories() {
    const grid = document.getElementById('shared-stories');
    if (!stories.length) {
      grid.innerHTML = '<div class="empty-board">עדיין אין סיפורים. היה/י הראשון/ה לשתף 💜</div>';
      return;
    }
    grid.innerHTML = stories.map((s, i) => `
      <div class="story-card">
        <span class="quote-mark">"</span>
        <p class="story-text">${escapeHtml(s.text)}</p>
        <div class="story-meta">
          <span>${timeAgo(s.time)}</span>
          <button class="like-btn ${likes[i] ? 'liked' : ''}" onclick="likeStory(${i})">
            ♥ ${s.likes || 0}
          </button>
        </div>
      </div>
    `).join('');
  }

  function likeStory(i) {
    if (likes[i]) return;
    stories[i].likes = (stories[i].likes || 0) + 1;
    likes[i] = true;
    localStorage.setItem('shared_stories', JSON.stringify(stories));
    localStorage.setItem('story_likes', JSON.stringify(likes));
    renderSharedStories();
  }

  // ─── PUBLISHED STORIES ───
  function renderPublishedStories() {
    const container = document.getElementById('published-stories');
    if (!publishedStories.length) {
      container.innerHTML = '<div class="empty-board">עדיין אין סיפורים מפורסמים. היוצרות יוסיפו בקרוב 💜</div>';
      return;
    }
    container.innerHTML = publishedStories.map(s => `
      <div class="pub-story">
        <div class="pub-story-header">
          <span class="pub-label">✦ סיפור מפורסם</span>
          <span class="pub-story-title">${escapeHtml(s.title)}</span>
        </div>
        <p class="pub-story-body">${escapeHtml(s.body)}</p>
        ${s.link ? `
        <div style="margin-top:1.2rem; padding-top:1rem; border-top:1px solid var(--light-gray);">
          <span style="font-size:0.82rem; color:var(--soft-gray); display:block; margin-bottom:0.4rem; font-weight:500;">רוצים ללמוד יותר?</span>
          <a href="${escapeHtml(s.link)}" target="_blank" rel="noopener" style="
            display:inline-flex; align-items:center; gap:0.4rem;
            color:var(--crimson); font-size:0.88rem; font-weight:600;
            text-decoration:none; transition:gap 0.2s;
          " onmouseenter="this.style.gap='0.65rem'" onmouseleave="this.style.gap='0.4rem'">
            לקריאה נוספת ←
          </a>
        </div>` : ''}
      </div>
    `).join('');
  }

  function addPublishedStory() {
    const title = document.getElementById('pub-title').value.trim();
    const body = document.getElementById('pub-body').value.trim();
    const link = document.getElementById('pub-link').value.trim();
    if (!title || !body) return toast('אנא מלאי כותרת ותוכן');
    publishedStories.push({ title, body, link });
    localStorage.setItem('published_stories', JSON.stringify(publishedStories));
    document.getElementById('pub-title').value = '';
    document.getElementById('pub-body').value = '';
    document.getElementById('pub-link').value = '';
    renderPublishedStories();
    toast('הסיפור פורסם בהצלחה ✓');
  }

  // ─── LOGIN ───
  function openLogin() {
    if (isAdmin) {
      document.getElementById('admin-panel').style.display = 'block';
      document.getElementById('admin-panel').scrollIntoView({ behavior: 'smooth' });
    } else {
      document.getElementById('login-modal').classList.add('active');
    }
  }

  function closeLogin() {
    document.getElementById('login-modal').classList.remove('active');
    document.getElementById('admin-password').value = '';
  }

  function checkLogin() {
    const pw = document.getElementById('admin-password').value;
    if (pw === ADMIN_PASS) {
      isAdmin = true;
      closeLogin();
      document.getElementById('admin-panel').style.display = 'block';
      toast('ברוכה הבאה, יוצרת! ✓');
    } else {
      toast('סיסמה שגויה');
      document.getElementById('admin-password').value = '';
    }
  }

  document.getElementById('admin-password').addEventListener('keydown', e => {
    if (e.key === 'Enter') checkLogin();
  });

  document.getElementById('login-modal').addEventListener('click', e => {
    if (e.target === document.getElementById('login-modal')) closeLogin();
  });

  // ─── UTILS ───
  function escapeHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function timeAgo(ts) {
    const diff = Date.now() - ts;
    const m = Math.floor(diff / 60000);
    if (m < 1) return 'עכשיו';
    if (m < 60) return `לפני ${m} דקות`;
    const h = Math.floor(m / 60);
    if (h < 24) return `לפני ${h} שעות`;
    return `לפני ${Math.floor(h / 24)} ימים`;
  }

  // ─── DILEMMA MODE ───
  let dilemmaData = {};

  function startDilemmaMode() {
    document.getElementById('dilemma-panel').style.display = 'block';
    document.getElementById('quick-chips').style.display = 'none';
    document.getElementById('dilemma-panel').scrollIntoView({ behavior: 'smooth', block: 'start' });
    resetDilemma();
  }

  function closeDilemmaMode() {
    document.getElementById('dilemma-panel').style.display = 'none';
    document.getElementById('quick-chips').style.display = 'flex';
  }

  function setDilemmaStep(n) {
    [1,2,3].forEach(i => {
      document.getElementById(`dilemma-step-${i}`).style.display = i === n ? 'block' : 'none';
    });
    const labels = ['שלב 1 מתוך 3 — תיאור המצב', 'שלב 2 מתוך 3 — ניתוח ערכים', 'שלב 3 מתוך 3 — המלצה'];
    document.getElementById('dilemma-step-label').textContent = labels[n-1];
    document.getElementById('dilemma-progress').style.width = (n * 33.3) + '%';
  }

  function dilemmaNext(from) {
    if (from === 1) {
      const sit = document.getElementById('dilemma-situation').value.trim();
      if (!sit) { toast('אנא תארי את המצב תחילה 💜'); return; }
      dilemmaData.situation = sit;
      setDilemmaStep(2);
    } else if (from === 2) {
      const harms = document.getElementById('dilemma-harms').value.trim();
      const benefits = document.getElementById('dilemma-benefits').value.trim();
      if (!harms || !benefits) { toast('אנא מלאי את שני הצדדים 💜'); return; }
      dilemmaData.harms = harms;
      dilemmaData.benefits = benefits;
      setDilemmaStep(3);
      runDilemmaAnalysis();
    }
  }

  function dilemmaBack() {
    setDilemmaStep(1);
  }

  function resetDilemma() {
    dilemmaData = {};
    document.getElementById('dilemma-situation').value = '';
    document.getElementById('dilemma-harms').value = '';
    document.getElementById('dilemma-benefits').value = '';
    document.getElementById('dilemma-loading').style.display = 'block';
    document.getElementById('dilemma-result').style.display = 'none';
    setDilemmaStep(1);
  }

  async function runDilemmaAnalysis() {
    document.getElementById('dilemma-loading').style.display = 'block';
    document.getElementById('dilemma-result').style.display = 'none';

    const prompt = `תלמיד/ה פנה/תה עם דילמה. אנא נתח/י אותה לעומק ותן/י המלצה מעשית.

**המצב:**
${dilemmaData.situation}

**ערכים שנפגעים:**
${dilemmaData.harms}

**ערכים שמרוויחים:**
${dilemmaData.benefits}

אנא ענה/י בעברית בלבד, במבנה הבא:

🔍 **הבנת הדילמה**
[ניסוח קצר ומדויק של הדילמה בשתי שורות — הראה שהבנת את הלב של הבעיה]

⚖️ **ניתוח הערכים**
[ניתח את המתח בין הערכים שהתלמיד ציין. אילו ערכים חשובים יותר במצב הזה ולמה? אל תהיה שטחי — תן עומק אמיתי]

✅ **הפתרון המומלץ**
[תן המלצה ברורה ומעשית — מה לעשות, שלב אחרי שלב. הסבר למה זה הפתרון הטוב ביותר לאור הערכים]

💡 **מה חשוב לזכור**
[משפט תמיכה אחד — חזק את הבחירה של התלמיד לחשוב על זה ולבקש עזרה]`;

    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1200,
          system: SYSTEM_PROMPT,
          messages: [{ role: 'user', content: prompt }]
        })
      });

      const data = await response.json();
      const analysis = data.content?.find(b => b.type === 'text')?.text || 'לא הצלחתי לנתח את הדילמה. נסי שוב.';

      dilemmaData.analysis = analysis;
      document.getElementById('dilemma-analysis-text').textContent = analysis;
      document.getElementById('dilemma-loading').style.display = 'none';
      document.getElementById('dilemma-result').style.display = 'block';

    } catch(err) {
      document.getElementById('dilemma-analysis-text').textContent = 'אירעה שגיאת חיבור. נסי שוב עוד רגע 💜';
      document.getElementById('dilemma-loading').style.display = 'none';
      document.getElementById('dilemma-result').style.display = 'block';
    }
  }

  function sendDilemmaToChat() {
    closeDilemmaMode();
    // Inject the full context into chat history silently, then show summary message
    const summary = `דנתי בדילמה: "${dilemmaData.situation.substring(0,80)}${dilemmaData.situation.length > 80 ? '...' : ''}"`;
    chatHistory.push({ role: 'user', content: `הנה הדילמה שלי:\n${dilemmaData.situation}\n\nהערכים שנפגעים: ${dilemmaData.harms}\nהערכים שמרוויחים: ${dilemmaData.benefits}\n\nקיבלתי ניתוח — אני רוצה להמשיך לדבר על זה.` });
    chatHistory.push({ role: 'assistant', content: dilemmaData.analysis });
    appendMessage('user', summary);
    appendMessage('bot', 'בוודאי 💜 ראיתי את הדילמה שלך וניתחנו אותה ביחד. מה עוד מקשה עליך/עליכם? יש שאלות נוספות שעלו?');
    document.getElementById('quick-chips').style.display = 'none';
  }
  const SYSTEM_PROMPT = `אתה "עוזר הנפש" — בוט תמיכה ייעודי לתלמידים באתר "די לאלימות".
תפקידך לסייע לתלמידים להתמודד עם דילמות, קשיים רגשיים, מצבים של אלימות (כלפיהם או כלפי אחרים), ולתת מענה עמוק, אנושי ומקצועי — בדומה לשיחה עם פסיכולוג בית ספרי.

עקרונות ליבה:
1. **הקשבה אמיתית** — לפני כל עצה, הראה שהבנת את מה שהמשתמש חווה. חזור על הרגשות שהוא ביטא, הכר בכאב שלו.
2. **עומק** — אל תתן תשובות שטחיות. שאל שאלות עומק כשצריך, הצע מסגרות לחשיבה, עזור לתלמיד להבין את עצמו.
3. **פתרון בעיות ללא אלימות** — תמיד הצע דרכים שאינן פוגעות באחרים. אם תלמיד מבטא רצון לפגוע במישהו — הכר ברגש הכעס אבל הפנה לדרכי התמודדות בריאות בלבד.
4. **מידע מעשי** — כשרלוונטי, ספק מידע על זכויות, ארגוני עזרה, ומספרי חירום (110 משטרה, 118 ERAN — קו נפש, 1202 עמותת איל).
5. **גבולות ברורים** — אתה לא מחליף פסיכולוג מקצועי. במצבים חמורים (סכנת נפשות, פגיעה עצמית) — הפנה מיידית לגורמי עזרה ומבוגר אחראי.
6. **שפה** — ענה תמיד בעברית בלבד. דבר בגובה העיניים, בחמימות אבל ברצינות. פנה תמיד בלשון זכר ונקבה גם יחד (לדוגמה: "אתה/את", "יכול/ה", "חש/ה").
7. **אסור** — לעולם אל תציע, לא ישירות ולא בעקיפין, פעולות שעלולות לפגוע בבני אדם.`;

  let chatHistory = [];
  let isBotTyping = false;

  function nowTime() {
    return new Date().toLocaleTimeString('he-IL', { hour: '2-digit', minute: '2-digit' });
  }

  function appendMessage(role, text) {
    const msgs = document.getElementById('chat-messages');
    const div = document.createElement('div');
    div.className = `msg ${role === 'user' ? 'user-msg' : 'bot-msg'}`;

    const bubble = document.createElement('div');
    bubble.className = role === 'user' ? 'user-bubble' : 'bot-bubble';
    bubble.textContent = text;

    const time = document.createElement('div');
    time.className = 'msg-time';
    time.textContent = nowTime();

    div.appendChild(bubble);
    div.appendChild(time);
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
    return bubble;
  }

  function setTyping(show) {
    document.getElementById('typing-indicator').style.display = show ? 'block' : 'none';
    const msgs = document.getElementById('chat-messages');
    msgs.scrollTop = msgs.scrollHeight;
  }

  function handleChatKey(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  }

  function autoResize(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 120) + 'px';
  }

  function quickSend(text) {
    document.getElementById('chat-input').value = text;
    sendMessage();
    // hide chips after first use
    document.getElementById('quick-chips').style.display = 'none';
  }

  async function sendMessage() {
    if (isBotTyping) return;
    const input = document.getElementById('chat-input');
    const text = input.value.trim();
    if (!text) return;

    // Add user message
    appendMessage('user', text);
    chatHistory.push({ role: 'user', content: text });
    input.value = '';
    input.style.height = 'auto';

    // Hide chips
    document.getElementById('quick-chips').style.display = 'none';

    // Show typing
    isBotTyping = true;
    document.getElementById('send-btn').style.opacity = '0.5';
    setTyping(true);

    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1000,
          system: SYSTEM_PROMPT,
          messages: chatHistory
        })
      });

      const data = await response.json();
      const reply = data.content?.find(b => b.type === 'text')?.text || 'מצטערת, משהו השתבש. נסי שוב.';

      setTyping(false);
      appendMessage('bot', reply);
      chatHistory.push({ role: 'assistant', content: reply });

    } catch (err) {
      setTyping(false);
      appendMessage('bot', 'אופס, נראה שיש בעיית חיבור. אנא נסי שוב עוד רגע 💜');
    }

    isBotTyping = false;
    document.getElementById('send-btn').style.opacity = '1';
  }
</script>
</body>
</html>
